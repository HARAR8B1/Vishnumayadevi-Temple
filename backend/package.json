{
  "name": "vishnumayadevi-temple-backend",
  "version": "2.0.0",
  "description": "Backend API for Sri Vishnu Maya Devi Amman Temple website — PostgreSQL powered",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
